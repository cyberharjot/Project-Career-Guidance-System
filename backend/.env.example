# FuturePath AI - Backend Environment Variables
# Copy this file to .env and fill in your real values

# Required: AI API token
GITHUB_TOKEN=your_api_key_here

# AI model settings
GITHUB_MODEL=openai/gpt-4.1-mini
GITHUB_BASE_URL=https://models.github.ai/inference

# Server port
# Render usually uses 10000, so we keep that here
FLASK_PORT=10000

# Optional: useful during local development
FLASK_DEBUG=true